# === 네가 채워야 하는 값 (이 파일을 .env 로 복사해서 입력) ===

# 1) Discord 봇 토큰
#    https://discord.com/developers/applications → New Application
#    → Bot 탭 → Reset Token → 복사
#    (Bot 탭에서 "MESSAGE CONTENT INTENT" 반드시 ON)
DISCORD_BOT_TOKEN=

# 2) 명령을 허용할 Discord 사용자 ID (쉼표로 여러 명)
#    Discord 설정 → 고급 → 개발자 모드 ON →
#    내 프로필 우클릭 → "ID 복사"
ALLOWED_USER_IDS=

# === 선택 (기본값으로 충분) ===
# omp 실행 파일 경로
OMP_BIN=/root/.bun/bin/omp
# 에이전트 작업 디렉토리
OMP_CWD=/root
# omp 실행 인자 (--yolo = 승인 없이 실행). 읽기전용만 원하면 비우거나 조정
OMP_ARGS=--yolo
# 에이전트 무응답 타임아웃(초)
OMP_IDLE_TIMEOUT=300
